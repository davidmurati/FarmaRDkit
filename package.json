{
  "name": "rdkit-pharma-dashboard",
  "version": "1.0.0",
  "description": "Panel de análisis farmacéutico con RDKit y dataset ESOL de Delaney",
  "main": "app.js",
  "scripts": {
    "start": "concurrently --kill-others --names \"PYTHON,NODE\" --prefix-colors \"cyan,green\" \"set PYTHONIOENCODING=utf-8 && python python/server.py\" \"node app.js\"",
    "dev": "concurrently --kill-others --names \"PYTHON,NODE\" --prefix-colors \"cyan,green\" \"set PYTHONIOENCODING=utf-8 && python python/server.py\" \"node app.js\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
